generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  phone     String?  @unique
  name      String?
  email     String?  @unique
  password  String?

  walletBalance   Int      @default(0)

  registeredSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  arenas       Arena[]
  walletTx     WalletTransaction[]
  otps         Otp[]
  arenaSettings ArenaSettings[]
}

model Player {
  id        String   @id @default(uuid())
  phone     String?  @unique
  name      String?
  email     String?  @unique
  password  String?

  walletBalance Int      @default(0)

  registeredSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings   Booking[]
  walletTx   WalletTransaction[]
  favourites FavouriteArena[]
  otps       Otp[]
}

model Arena {
  id          String   @id @default(uuid())
  ownerId     String

  name        String
  description String?
  address     String
  city        String
  phone       String?
  email       String?

  latitude    Float?
  longitude   Float?

  images      String[]
  isActive    Boolean  @default(true)

  terms       String?
  customMsg   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User     @relation(fields: [ownerId], references: [id])

  bookings      Booking[]
  favourites    FavouriteArena[]
  gameTypes     GameType[]
  arenaSettings ArenaSettings?

  @@index([city])
  @@index([isActive])
}

model ArenaSettings {
  id               String   @id @default(uuid())
  arenaId          String   @unique
  ownerId          String
  bookingCloseMins Int      @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  arena             Arena              @relation(fields: [arenaId], references: [id])
  owner             User               @relation(fields: [ownerId], references: [id])
  cancellationRules CancellationRule[]
}

model CancellationRule {
  id              String        @id @default(uuid())
  arenaSettingsId String
  hoursBeforeSlot Int
  refundPercent   Int

  arenaSettings ArenaSettings @relation(fields: [arenaSettingsId], references: [id], onDelete: Cascade)
}

model GameType {
  id       String   @id @default(uuid())
  name     String
  isActive Boolean? @default(true)
  arenaId  String

  arena  Arena   @relation(fields: [arenaId], references: [id])
  courts Court[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Court {
  id           String  @id @default(uuid())
  name         String
  gameTypeId   String
  isActive     Boolean @default(true)
  slotDuration Int     @default(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gameType GameType               @relation(fields: [gameTypeId], references: [id])
  slotDefs SlotDefinitionGroups[]
  bookings Booking[]
  slots    Slot[]
}

model SlotDefinitionGroups {
  id      String    @id @default(uuid())
  courtId String
  date    DateTime?
  dayType String    // CUSTOM | MONDAY..SUNDAY
  price   Int?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  court    Court            @relation(fields: [courtId], references: [id])
  slotDefs SlotDefinition[]

  @@unique([courtId, dayType])
}

model SlotDefinition {
  id             String    @id @default(uuid())
  slotDefGroupId String
  startTime      String    // "06:00"
  endTime        String    // "07:00"
  date           DateTime?
  price          Int?

  slotDefGroup SlotDefinitionGroups @relation(fields: [slotDefGroupId], references: [id], onDelete: Cascade)
}

model Slot {
  id        String   @id @default(uuid())
  courtId   String
  date      DateTime
  startTime String   // "06:00" — stored as string for simplicity
  endTime   String   // "07:00"
  price     Int
  status    String   @default("AVAILABLE") // AVAILABLE | BOOKED | BLOCKED

  court    Court     @relation(fields: [courtId], references: [id])
  bookings Booking[]

  @@unique([courtId, date, startTime])
}

model Booking {
  id       String  @id @default(uuid())
  playerId String
  arenaId  String
  slotId   String
  courtId  String
  price    Int
  status   String  // CONFIRMED | CANCELLED | COMPLETED
  reason   String?

  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])
  slot   Slot   @relation(fields: [slotId], references: [id])
  arena  Arena  @relation(fields: [arenaId], references: [id])
  court  Court  @relation(fields: [courtId], references: [id])

  @@index([arenaId, createdAt])
  @@index([status])
  @@index([playerId])
}

model WalletTransaction {
  id          String  @id @default(uuid())
  playerId    String?
  userId      String?
  amount      Int
  type        String  // DEBIT | CREDIT
  source      String  // BOOKING | REFUND | MANUAL | SETTLEMENT | WITHDRAWAL
  referenceId String?
  reason      String?
  isAdmin     Boolean @default(false)

  createdAt DateTime @default(now())

  player Player? @relation(fields: [playerId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([playerId])
  @@index([userId])
  @@index([createdAt])
}

model FavouriteArena {
  id       String @id @default(uuid())
  playerId String
  arenaId  String

  player Player @relation(fields: [playerId], references: [id])
  arena  Arena  @relation(fields: [arenaId], references: [id])

  @@unique([playerId, arenaId])
}

model Otp {
  id       String  @id @default(uuid())
  playerId String?
  userId   String?
  email    String
  otpHash  String
  attempts Int     @default(0)
  userType String  // PLAYER | USER
  expiresAt DateTime
  verified  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  player Player? @relation(fields: [playerId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([userId])
  @@index([email, userType])
  @@index([expiresAt])
}
