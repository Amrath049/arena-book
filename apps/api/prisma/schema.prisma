model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?

  walletBalance   Int      @default(0)

  registeredSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  arenas    Arena[]
  walletTx  WalletTransaction[]
}

model Player {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?

  walletBalance Int      @default(0)

  registeredSource String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings  Booking[]
  walletTx  WalletTransaction[]
  favourites FavouriteArena[]
}

model Arena {
  id          String   @id @default(uuid())
  ownerId     String

  name        String
  description String?
  address     String
  city        String
  phone       String?
  email       String?

  latitude    Float?
  longitude   Float?

  images      String[]
  isActive    Boolean  @default(true)

  terms       String?
  customMsg   String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner      User     @relation(fields: [ownerId], references: [id])

  bookings   Booking[]
  favourites FavouriteArena[]
  gameTypes  GameType[]

  @@index([city])
  @@index([isActive])
}

model GameType {
  id          String   @id @default(uuid())
  name        String
  isActive    Boolean?  @default(true)
  arenaId     String

  arena       Arena    @relation(fields: [arenaId], references: [id])

  courts      Court[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Court {
  id          String   @id @default(uuid())

  name        String
  gameTypeId  String
  
  isActive    Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  gameType    GameType @relation(fields: [gameTypeId], references: [id])

  slotDefs    SlotDefinitionGroups[]
  bookings    Booking[]
  slots       Slot[]
}

model SlotDefinitionGroups {
  id        String   @id @default(uuid())

  courtId  String

  date      DateTime?

  dayType   String   //  CUSTOM | SUNDAY to SATURDAY
  price     Int?

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  court     Court @relation(fields: [courtId], references: [id])

  slotDefs  SlotDefinition[]

  @@unique([courtId, dayType])
}

model SlotDefinition {
  id        String   @id @default(uuid())

  slotDefGroupId String

  startTime String   // "06:00"
  endTime   String   // "07:00"
  date      DateTime?
  price     Int?

  slotDefGroup     SlotDefinitionGroups @relation(fields: [slotDefGroupId], references: [id])
}


model Slot {
  id        String     @id @default(uuid())

  courtId   String

  date      DateTime
  startTime DateTime
  endTime   DateTime

  price     Int
  status    String @default("AVAILABLE") // AVAILABLE | BOOKED | BLOCKED

  court     Court      @relation(fields: [courtId], references: [id])
  booking   Booking?

  @@unique([courtId, date, startTime])
}

model Booking {
  id        String        @id @default(uuid())

  playerId  String
  arenaId   String
  slotId    String        @unique
  courtId   String
  
  price    Int
  status    String  // CONFIRMED | CANCELLED | REFUNDED |COMPLETED
  reason    String?

  createdAt DateTime      @default(now())
 
  player    Player       @relation(fields: [playerId], references: [id])
  slot      Slot         @relation(fields: [slotId], references: [id])
  arena     Arena        @relation(fields: [arenaId], references: [id])
  court     Court        @relation(fields: [courtId], references: [id])

  @@index([arenaId, createdAt])
  @@index([status])
}

model WalletTransaction {
  id        String          @id @default(uuid())

  playerId  String?
  userId    String?
  
  amount    Int
  type      String  //DEBIT, CREDIT
  source    String  //BOOKING | REFUND | MANUAL | SETTLEMENT

  referenceId String?
  reason    String?

  isAdmin   Boolean  @default(false)

  createdAt DateTime        @default(now())

  player    Player?         @relation(fields: [playerId], references: [id])
  user      User?           @relation(fields: [userId], references: [id])

  @@index([playerId])
  @@index([userId])
  @@index([createdAt])
} 

model FavouriteArena {
  id        String @id @default(uuid())

  playerId  String
  arenaId   String

  player    Player @relation(fields: [playerId], references: [id])
  arena     Arena  @relation(fields: [arenaId], references: [id])

  @@unique([playerId, arenaId])
}